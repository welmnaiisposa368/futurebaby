# ✅ Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ✅ PayPal 配置
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_ENVIRONMENT=sandbox

# ✅ Replicate API（用于生成未来宝宝图片）
REPLICATE_API_TOKEN=

# ✅ ElevenLabs API（用于生成宝宝声音）
ELEVENLABS_API_KEY=

# ✅ Next.js 公共站点地址（用于构建链接等）
NEXT_PUBLIC_SITE_URL=

# ✅ 新定价配置
ONETIME_PLAN_PRICE=5.90
MONTHLY_PLAN_PRICE=12.90
YEARLY_PLAN_PRICE=39.90

CREDITS_2_PRICE=8.90
CREDITS_5_PRICE=19.90
CREDITS_10_PRICE=39.90

# ✅ NextAuth配置
NEXTAUTH_SECRET=your_nextauth_secret_32_characters
NEXTAUTH_URL=https://your-domain.com

# ✅ 可选：调试/日志设置
NEXT_PUBLIC_ENVIRONMENT=development

